# MongoDB Atlas connection string
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority

# Port the server runs on (Render sets this automatically — leave as is)
PORT=5000

# Comma-separated list of allowed frontend origins, e.g.
# https://sumedh-portfolio.vercel.app,http://localhost:5500
# Use * only for local testing, never in production
CORS_ORIGIN=*

# Gmail address used to send notification emails (requires an App Password,
# not your regular Gmail password — see deployment notes)
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_16_char_gmail_app_password

# Where contact form notifications get sent (defaults to SMTP_USER if unset)
NOTIFY_EMAIL=sumedhpatil700@gmail.com

# Secret key required to access admin endpoints — make this long and random
ADMIN_KEY=choose_a_long_random_string_here
